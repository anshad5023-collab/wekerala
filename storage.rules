rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // APK downloads — public read
    match /apk/{allPaths=**} {
      allow read;
      allow write: if false;
    }

    // Windows installer and other release binaries — public read
    match /releases/{allPaths=**} {
      allow read;
      allow write: if false;
    }
    // Shop assets (banners, product images, photos) — public read, owner-only write
    // Verifies the authenticated user is the shop owner via Firestore lookup
    match /shops/{shopId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null &&
                      firestore.get(/databases/(default)/documents/shops/$(shopId)).data.ownerId
                      == request.auth.uid;
    }
  }
}
