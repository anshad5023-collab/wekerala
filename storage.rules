rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // APK downloads — public read
    match /apk/{allPaths=**} {
      allow read;
      allow write: if false;
    }

    // Windows installer and other release binaries — public read
    match /releases/{allPaths=**} {
      allow read;
      allow write: if false;
    }
    // Shop assets (banners, product images, photos) — public read, auth write
    match /shops/{shopId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }
  }
}
